rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ВАЖНО: замените строку ниже на UID вашего администратора из Authentication → Users.
    function bootstrapAdmin() { return request.auth != null && request.auth.uid == 'BBdM0CUz7jgSGGc0R6Oj1Q7rBBQ2'; }
    function isAdmin() { return request.auth != null && (bootstrapAdmin() || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'); }
    match /lessons/{id} {
      allow read: if true;
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']) && request.resource.data.views == resource.data.views + 1);
    }
    match /articles/{id} { allow read: if true; allow write: if isAdmin(); }
    match /messages/{id} { allow create: if true; allow read, update, delete: if isAdmin(); }
    match /comments/{id} { allow read: if true; allow create: if request.auth != null; allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId; }
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // Пользователь не способен назначить себе admin: роль меняет только bootstrap/admin.
      allow create: if request.auth != null && request.auth.uid == userId && (request.resource.data.role == 'user' || (bootstrapAdmin() && request.resource.data.role == 'admin'));
      allow update: if isAdmin() || (request.auth != null && request.auth.uid == userId && request.resource.data.role == resource.data.role);
    }
  }
}
