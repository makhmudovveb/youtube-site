# Скопируйте в .env.local и укажите значения проекта Firebase.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Пока false или отсутствует — сайт работает на mock-данных.
VITE_USE_FIREBASE=false
# Cloudinary: Dashboard → Settings → Upload → Upload presets → unsigned.
# Не добавляйте API Secret в Vite-переменные: он должен оставаться секретным.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
# UID единственного первого администратора. Он есть в Firebase Authentication → Users.
# Этот же UID укажите в firestore.rules вместо PASTE_YOUR_FIREBASE_UID_HERE.
VITE_ADMIN_UID=
