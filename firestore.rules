rules_version = '2';
service cloud.firestore { match /databases/{database}/documents {
  match /lessons/{id} { allow read: if true; allow write: if request.auth != null; }
  match /articles/{id} { allow read: if true; allow write: if request.auth != null; }
  match /messages/{id} { allow create: if true; allow read, update, delete: if request.auth != null; }
  match /comments/{id} { allow read: if true; allow create: if request.auth != null; allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId; }
} }
